# almi-billing-router — env (founder sets all of these in Vercel; never commit real values)

# Neon (its OWN database, separate from every product and from almi-monitor)
DATABASE_URL=postgresql://…?sslmode=require&pgbouncer=true      # pooled, runtime
DATABASE_URL_UNPOOLED=postgresql://…?sslmode=require            # direct, migrations

# The signing secret of the router's Stripe event destination. In the "convert" migration this is
# the whsec of the repurposed CELPIP destination (unchanged when its URL is repointed).
STRIPE_WEBHOOK_SECRET=whsec_…

# Bearer token for the /api/admin/routes registry endpoint (abba generates).
ADMIN_API_SECRET=…

# NOT required: the router holds NO Stripe SECRET key by design (signature verification is offline).
# STRIPE_SECRET_KEY is only ever needed if we later add the optional restricted read-only fallback.
